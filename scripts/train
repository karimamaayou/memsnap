#!/usr/bin/env python3

"""Train a multi-output Decision Tree classifier on features.csv."""

import argparse, sys
from pathlib import Path
import pandas as pd
from sklearn.tree import DecisionTreeClassifier
from sklearn.multioutput import MultiOutputClassifier
from sklearn.model_selection import LeaveOneOut, cross_val_score
import joblib

if __name__ == "__main__":
    p = argparse.ArgumentParser(description="Train the detection model")
    p.add_argument("-i", "--input", required=True, help="Path to features CSV")
    p.add_argument("-o", "--output", default="model.pkl", help="Where to save the trained model")
    args = p.parse_args()

    if not Path(args.input).exists():
        print(f"Error: file not found: {args.input}")
        sys.exit(1)

    df = pd.read_csv(args.input)
    FEATURES = ["hidden_module_count", "has_injection", "high_port_listeners", "total_sockets"]
    LABELS   = ["label_rootkit", "label_injection", "label_backdoor"]
    X = df[FEATURES]
    y = df[LABELS]

    loo = LeaveOneOut()
    print("Per-label LOO accuracy:")
    for label in LABELS:
        clf = DecisionTreeClassifier(random_state=42)
        scores = cross_val_score(clf, X, y[label], cv=loo, scoring="accuracy")
        print(f"  {label}: {scores.mean():.2f}")

    clf_multi = MultiOutputClassifier(DecisionTreeClassifier(random_state=42))
    exact = cross_val_score(clf_multi, X, y, cv=loo, scoring="accuracy")
    print(f"Exact match accuracy: {exact.mean():.2f}")

    clf_multi.fit(X, y)
    joblib.dump(clf_multi, args.output)
    print(f"Model saved to {args.output}")

    print("\nLearned rules:")
    for est, label in zip(clf_multi.estimators_, LABELS):
        tree = est.tree_
        if tree.node_count > 1:
            feat = FEATURES[tree.feature[0]]
            thresh = tree.threshold[0]
            print(f"  {label}: {feat} <= {thresh:.1f}")
        else:
            print(f"  {label}: constant leaf")
