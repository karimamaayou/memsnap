install_hollowing() {
    echo "[*] Starting process hollowing..."
    "$ASSETS_DIR/build/process_hollow" /usr/bin/id && set_flag "hollowing"
}

clean_hollowing() {
    echo "[*] Cleaning process hollowing..."
    if [ -f /tmp/process_hollow.pid ]; then
        kill $(cat /tmp/process_hollow.pid) 2>/dev/null || true
        rm -f /tmp/process_hollow.pid
    fi
    clear_flag "hollowing"
}
