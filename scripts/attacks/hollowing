install_hollowing() {
    [ -f /tmp/.hollowing_active ] && return 0
    "$ASSETS_DIR/build/process_hollow" /usr/bin/id
    touch /tmp/.hollowing_active
    echo "[+] Process hollowing deployed"
}
clean_hollowing() {
    # The hollowed process (shell) cannot be easily identified
    # without modifying the C binary. Remove the flag only.
    rm -f /tmp/.hollowing_active
    echo "[!] Hollowing flag removed – child process may still be running"
}
