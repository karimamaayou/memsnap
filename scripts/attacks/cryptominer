# Cryptominer simulation (CPU burn + fake sockets)
install_cryptominer() {
    echo "[*] Starting cryptominer simulation..."
    "$ASSETS_DIR/build/miner_sim" && set_flag "cryptominer"
}

clean_cryptominer() {
    echo "[*] Cleaning cryptominer..."
    if [ -f /tmp/miner_sim.pid ]; then
        kill $(cat /tmp/miner_sim.pid) 2>/dev/null || true
        rm -f /tmp/miner_sim.pid
    fi
    pkill -f "miner_sim" 2>/dev/null || true
    clear_flag "cryptominer"
}
