install_persistence() {
    echo "[*] Setting up persistence..."
    "$ASSETS_DIR/build/ld_preload_installer"
    (crontab -l 2>/dev/null; echo '* * * * * echo "p" >> /tmp/persist.log') | crontab -
    echo "[+] Cron job added"
    set_flag "persistence"
}

clean_persistence() {
    echo "[*] Cleaning persistence..."
    rm -f /usr/lib/libpreload.so
    sed -i '/libpreload/d' /etc/ld.so.preload 2>/dev/null || true
    crontab -l 2>/dev/null | grep -v "persist.log" | crontab - 2>/dev/null || true
    rm -f /tmp/persist.log
    clear_flag "persistence"
}
