# Diamorphine kernel module
install_rootkit() {
    echo "[*] Installing rootkit (Diamorphine)..."
    if [ -f "$ASSETS_DIR/diamorphine.ko" ]; then
        insmod "$ASSETS_DIR/diamorphine.ko" 2>/dev/null && \
            echo "[+] Diamorphine loaded" || echo "[-] insmod failed"
    else
        echo "[-] diamorphine.ko not found at $ASSETS_DIR/diamorphine.ko"
    fi
    set_flag "rootkit"
}

clean_rootkit() {
    echo "[*] Cleaning rootkit..."
    rmmod diamorphine 2>/dev/null && echo "[+] Diamorphine unloaded" || true
    clear_flag "rootkit"
}
