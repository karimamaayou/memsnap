install_fileless_shm() {
    echo "[*] Starting fileless shared memory execution..."
    "$ASSETS_DIR/build/fileless_shm" "$ASSETS_DIR/build/pause_binary" && set_flag "fileless_shm"
}

clean_fileless_shm() {
    echo "[*] Cleaning fileless shared memory..."
    pkill -f "/dev/shm/xSHM_PAYLOAD" 2>/dev/null || true
    rm -f /dev/shm/xSHM_PAYLOAD
    clear_flag "fileless_shm"
}
