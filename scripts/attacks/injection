# /proc/$pid/mem injection (alternative method)
install_injection() {
    echo "[*] Starting /proc/$pid/mem injection..."
    # Start target process
    sleep 9998 &
    SLEEP_PID=$!
    echo $SLEEP_PID > /tmp/procmem_target.pid
    echo "[*] Target PID: $SLEEP_PID"
    
    sleep 0.5
    "$ASSETS_DIR/build/ptrace_inject_v2" $SLEEP_PID && set_flag "injection"
}

clean_injection() {
    echo "[*] Cleaning /proc/$pid/mem injection..."
    if [ -f /tmp/procmem_target.pid ]; then
        kill $(cat /tmp/procmem_target.pid) 2>/dev/null || true
        rm -f /tmp/procmem_target.pid
    fi
    pkill -f "sleep 9998" 2>/dev/null || true
    clear_flag "injection"
}
