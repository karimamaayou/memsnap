#!/usr/bin/env python3

"""extract_feats - Process a directory of memory dumps, extract features, write CSV."""

import argparse, csv, json, subprocess, sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
ASSETS_DIR = SCRIPT_DIR / ".." / "assets"

PLUGINS = [
    "linux.pslist",
    "linux.psscan",
    "linux.check_syscall",
    "linux.hidden_modules",
    "linux.sockstat",
    "linux.lsof.Lsof",
]

SENTINEL = -1
INJECTION_MARKER_NAME = "injection_marker"

def run_vol_plugin(dump_path, plugin):
    cmd = ["vol", "-f", dump_path, "-s", str(ASSETS_DIR), "--renderer", "json", plugin]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=400)
        if proc.returncode != 0 or not proc.stdout.strip():
            return []
        data = json.loads(proc.stdout)
        if isinstance(data, list): return data
        if isinstance(data, dict): return data.get("rows", data.get("data", []))
        return []
    except Exception as e:
        print(f"  [!] {plugin} failed: {e}", file=sys.stderr)
        return []

def extract_features(dump_path):
    features = {}
    results = {}
    for plugin in PLUGINS:
        print(f"    running {plugin}...")
        results[plugin] = run_vol_plugin(dump_path, plugin)

    pslist = results.get("linux.pslist", [])
    psscan = results.get("linux.psscan", [])
    if pslist and psscan:
        try:
            pids_list = {r.get("PID") for r in pslist if isinstance(r, dict)}
            pids_scan = {r.get("PID") for r in psscan if isinstance(r, dict)}
            features["hidden_proc_count"] = len(pids_scan - pids_list)
        except:
            features["hidden_proc_count"] = SENTINEL
    else:
        features["hidden_proc_count"] = SENTINEL

    chk = results.get("linux.check_syscall", [])
    if chk:
        try:
            features["hooked_syscall_count"] = sum(
                1 for r in chk if isinstance(r, dict) and r.get("Hooked", False))
        except:
            features["hooked_syscall_count"] = SENTINEL
    else:
        features["hooked_syscall_count"] = SENTINEL

    hidden_mods = results.get("linux.hidden_modules", [])
    features["hidden_module_count"] = len(hidden_mods) if hidden_mods else 0

    sockstat = results.get("linux.sockstat", [])
    if sockstat:
        features["total_sockets"] = len(sockstat)
        high = 0
        for s in sockstat:
            if not isinstance(s, dict): continue
            port = s.get("Source Port") or s.get("Local Port") or s.get("Port") or 0
            try:
                if int(port) == 4444: high += 1
            except:
                pass
        features["high_port_listeners"] = high
    else:
        features["total_sockets"] = SENTINEL
        features["high_port_listeners"] = SENTINEL

    has_inj = 0
    lsof_rows = results.get("linux.lsof.Lsof", [])
    if lsof_rows:
        for row in lsof_rows:
            if isinstance(row, dict) and any(
                isinstance(v, str) and INJECTION_MARKER_NAME in v for v in row.values()
            ):
                has_inj = 1
                break
    else:
        for proc in pslist:
            if isinstance(proc, dict):
                cmd = proc.get("Command", proc.get("COMMAND", ""))
                if isinstance(cmd, str) and "sleep 9999" in cmd:
                    has_inj = 1
                    break
    features["has_injection"] = has_inj

    return features

def parse_labels(filename):
    stem = Path(filename).stem
    parts = stem.split("_")
    labels = {"label_rootkit": 0, "label_injection": 0, "label_backdoor": 0}
    tags = parts[3:] if len(parts) >= 4 else parts[2:]
    if "clean" in tags: return labels
    for t in tags:
        if t == "rootkit": labels["label_rootkit"] = 1
        elif t == "injection": labels["label_injection"] = 1
        elif t == "backdoor": labels["label_backdoor"] = 1
    return labels

def process_directory(input_dir, output_csv="features.csv", append=False):
    input_path = Path(input_dir)
    dumps = sorted(list(input_path.glob("*.raw")) + list(input_path.glob("*.lime")) + list(input_path.glob("*.dmp")))
    if not dumps:
        print(f"[!] No dump files found in {input_dir}")
        sys.exit(1)

    print(f"[*] Found {len(dumps)} dump(s). Starting extraction...\n")
    rows = []
    for i, dump_file in enumerate(dumps, 1):
        print(f"  [{i}/{len(dumps)}] {dump_file.name}")
        labels = parse_labels(dump_file.name)
        feats  = extract_features(str(dump_file))
        row = {"dump_name": dump_file.name}
        row.update(labels)
        row.update(feats)
        rows.append(row)
        print()

    if not rows:
        print("[!] No rows generated.")
        return

    order = ["dump_name", "label_rootkit", "label_injection", "label_backdoor",
             "hidden_proc_count", "hooked_syscall_count", "hidden_module_count",
             "total_sockets", "high_port_listeners", "has_injection"]
    extra = [k for k in rows[0] if k not in order]
    fieldnames = order + extra

    exists = Path(output_csv).exists()
    mode = 'a' if append and exists else 'w'
    with open(output_csv, mode, newline="") as f:
        w = csv.DictWriter(f, fieldnames=fieldnames)
        if not (append and exists): w.writeheader()
        w.writerows(rows)

    action = "appended" if (append and exists) else "written"
    print(f"[+] {len(rows)} rows {action} to {output_csv}")

    if not append:
        print("\nQuick sanity check:")
        for col in fieldnames[4:]:
            vals = [r[col] for r in rows]
            unique = sorted(set(vals))
            flag = " <- ! all identical" if len(unique) == 1 else ""
            print(f"  {col:30s} unique={unique}{flag}")

if __name__ == "__main__":
    p = argparse.ArgumentParser(description="Extract forensic features from memory dumps")
    p.add_argument("input_dir", help="Directory with memory dumps")
    p.add_argument("output_csv", nargs="?", default="features.csv", help="Output CSV")
    p.add_argument("--append", action="store_true", help="Append to existing CSV")
    args = p.parse_args()
    process_directory(args.input_dir, args.output_csv, args.append)
