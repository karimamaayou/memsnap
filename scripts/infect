#!/usr/bin/env bash
# MemSnap infect – modular multi‑attack manager
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ATTACKS_DIR="$SCRIPT_DIR/attacks"
export ASSETS_DIR="$SCRIPT_DIR/../assets"

INSTALL_COMPLETION=false
ACTION=""
CAPTURE=false
OUTPUT_DIR="."
SELECTED=()

usage() {
    echo "Usage: $0 [options]"
    echo "  -I          Install bash completion"
    echo "  -A <attack> Add attack to queue (repeatable)"
    echo "  -D <attack> Remove attack from queue"
    echo "  -l          List attacks in queue"
    echo "  -r          Run queued attacks (install)"
    echo "  -R          Reverse queued attacks (clean)"
    echo "  -s          Show active attacks"
    echo "  -a [dir]    Capture memory after -r/-R (optional dir)"
    exit 1
}

while getopts "IA:D:lrRa:s" opt; do
    case $opt in
        I) INSTALL_COMPLETION=true ;;
        A) SELECTED+=("$OPTARG") ;;
        D)
            for i in "${!SELECTED[@]}"; do
                [ "${SELECTED[$i]}" = "$OPTARG" ] && unset 'SELECTED[$i]'
            done
            ;;
        l) echo "${SELECTED[*]:-none}"; exit 0 ;;
        r) ACTION="install" ;;
        R) ACTION="clean" ;;
        a) CAPTURE=true
           [ -n "${!OPTIND}" ] && [[ "${!OPTIND}" != -* ]] && { OUTPUT_DIR="${!OPTIND}"; OPTIND=$((OPTIND+1)); }
           ;;
        s) ACTION="status" ;;
        *) usage ;;
    esac
done
shift $((OPTIND-1))

if $INSTALL_COMPLETION; then
    cat > "$SCRIPT_DIR/memsnap-completion.bash" << 'EOF'
#!/usr/bin/env bash
_attack_list="rootkit injection backdoor reverse_shell ptrace_injection hollowing deleted_exe persistence cred_scrape cryptominer"
_memsnap_infect_completion() {
    local cur prev
    _init_completion || return
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    case "$prev" in
        -A|-D|-r|-R) COMPREPLY=( $(compgen -W "$_attack_list" -- "$cur") ); return ;;
        *) COMPREPLY=( $(compgen -W "-l -r -R -A -D -a -s -I" -- "$cur") ); return ;;
    esac
}
complete -F _memsnap_infect_completion ./scripts/infect
EOF
    echo "[+] Completion script written to scripts/memsnap-completion.bash"
    exit 0
fi

if [ "$ACTION" = "status" ]; then
    active=()
    for script in "$ATTACKS_DIR"/*; do
        name=$(basename "$script")
        [ -f "/tmp/.${name}_active" ] && active+=("$name")
    done
    [ ${#active[@]} -eq 0 ] && echo "[+] Machine is clean." || echo "[!] Active: ${active[*]}"
    exit 0
fi

[ -z "$ACTION" ] && usage
[ ${#SELECTED[@]} -eq 0 ] && { echo "[!] No attacks selected. Use -A." >&2; exit 1; }

for attack in "${SELECTED[@]}"; do
    script="$ATTACKS_DIR/$attack"
    [ -x "$script" ] || { echo "[!] Unknown attack: $attack" >&2; exit 1; }
    source "$script"
    if [ "$ACTION" = "install" ]; then
        install_$attack
    else
        clean_$attack
    fi
done

echo "[+] $ACTION complete."

if $CAPTURE; then
    AVML_DIR="$HOME/.local/bin"
    AVML_BIN="$AVML_DIR/avml"
    [ -x "$AVML_BIN" ] || {
        mkdir -p "$AVML_DIR"
        wget -q "https://github.com/microsoft/avml/releases/download/v0.14.0/avml" -O "$AVML_BIN"
        chmod +x "$AVML_BIN"
    }
    ts=$(date +%Y%m%d_%H%M%S)
    comps=()
    for script in "$ATTACKS_DIR"/*; do
        name=$(basename "$script")
        [ -f "/tmp/.${name}_active" ] && comps+=("$name")
    done
    [ ${#comps[@]} -eq 0 ] && comps=("clean")
    IFS=_
    filename="memdump_${ts}_${comps[*]}.raw"
    mkdir -p "$OUTPUT_DIR"
    echo "[*] Capturing to $OUTPUT_DIR/$filename ..."
    sudo "$AVML_BIN" --compress "$OUTPUT_DIR/$filename"
    echo "[+] Dump saved."
fi
