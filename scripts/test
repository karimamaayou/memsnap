#!/usr/bin/env bash

# test - run detect on every dump in a directory

DIR="${1:-dumps}"
if [ ! -d "$DIR" ]; then
    echo "Usage: $( basename $0 ) <directory_of_dumps>"
    exit 1
fi

for dump in "$DIR"/*.raw "$DIR"/*.lime "$DIR"/*.dmp; do
    [ -f "$dump" ] || continue
    echo "=== $(basename "$dump") ==="
    ./memsnap detect "$dump"
    echo
done

